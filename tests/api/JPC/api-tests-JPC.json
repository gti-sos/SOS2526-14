    {
      "name": "GET/loadInitialData - 201",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Carga inicial exitosa (201) o datos ya existentes (400)\", function () {\r",
              "    // Comprobamos que el código de respuesta sea UNO DE esos dos\r",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);\r",
              "});\r",
              "\r",
              "pm.test(\"Devuelve el mensaje correcto en cada caso\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    if (pm.response.code === 201) {\r",
              "        pm.expect(jsonData.message).to.eql(\"Datos cargados correctamente\");\r",
              "    } else if (pm.response.code === 400) {\r",
              "        pm.expect(jsonData.error).to.eql(\"La base de datos ya tiene datos.\");\r",
              "    }\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
