    {
      "name": "Get recurso-200",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Comprobar el código de estado\r",
              "pm.test(\"Estado de respuesta es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Comprobar el contenido del objeto\r",
              "pm.test(\"El recurso devuelto es el correcto\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    \r",
              "    // Verificamos que los campos clave existen\r",
              "    pm.expect(jsonData).to.have.property(\"name\");\r",
              "    pm.expect(jsonData).to.have.property(\"country\");\r",
              "    \r",
              "    // Verificamos que los valores coinciden con lo solicitado\r",
              "    pm.expect(jsonData.name).to.equal(\"COSMIC-B\");\r",
              "    pm.expect(jsonData.country).to.equal(\"Taiwan\");\r",
              "    \r",
              "    // Comprobamos que un campo técnico tiene el formato esperado (string en tu caso)\r",
              "    pm.expect(jsonData.launch_mass).to.be.a(\"string\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
