    {
      "name": "GET-200",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"La respuesta es un array con datos\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    \r",
              "    // Comprobamos que es un array\r",
              "    pm.expect(jsonData).to.be.an(\"array\");\r",
              "    \r",
              "    // Comprobamos que al menos tiene un elemento\r",
              "    pm.expect(jsonData.length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "pm.test(\"El primer elemento tiene los campos correctos\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    const firstItem = jsonData[0];\r",
              "    \r",
              "    pm.expect(firstItem).to.have.property(\"name\");\r",
              "    pm.expect(firstItem).to.have.property(\"country\");\r",
              "    pm.expect(firstItem).to.have.property(\"launch_date\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
